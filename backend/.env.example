# ── SMTP Email Configuration ──────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# .env is gitignored — .env.example is safe to commit (no real secrets here).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=Melody Wings Safety

# Comma-separated list of addresses that receive alerts and summaries
ALERT_RECIPIENTS=analyst@yourorg.com,supervisor@yourorg.com

# Minimum severity level to trigger automatic alerts: High or Critical
ALERT_SEVERITY=High

# Frontend URL — used to generate "View Report" links in emails
APP_URL=http://localhost:5173

# ── MongoDB Configuration ─────────────────────────────────────────────────────
# Primary data store for all analysis results, transcripts, findings, and audit logs.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?...
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_DB_NAME=audio_safety_db

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# IAM user needs: s3:PutObject, s3:GetObject, s3:DeleteObject on the bucket
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name   # note: env var is S3_BUCKET_NAME — config.py reads S3_BUCKET

# ── ML Classifier ─────────────────────────────────────────────────────────────
# Enabled by default — critical for detection accuracy.
# The ~400 MB distilbert-mnli model is downloaded automatically on first run.
# Set to false only if you need to skip ML inference (e.g. CI without GPU).
ENABLE_ML_CLASSIFIER=true

# Path to a fine-tuned model directory (relative to backend/).
# Run `python finetune_model.py` to generate one. Leave blank to use the base model.
FINETUNED_MODEL_PATH=

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=200
MAX_VIDEO_UPLOAD_MB=500

# ── LLM summary (Ollama) ──────────────────────────────────────────────────────
# Set to false to skip Ollama calls entirely (faster; uses rule-based summary only).
ENABLE_LLM_SUMMARY=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For production, replace with your actual frontend domain.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Authentication ────────────────────────────────────────────────────────────
# Set a strong random string to enable API key authentication.
# Every request must include the header:  X-API-Key: <value>
# Leave blank to disable auth (local development only).
API_KEY=

# JWT Authentication (used by the frontend login)
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production — server refuses to start without it when ENV=production.
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRE_MINUTES=480

# ── Environment Mode ──────────────────────────────────────────────────────────
# Set to "production" or "staging" to enable strict startup checks
# (e.g. JWT_SECRET must be set). Default: development.
ENV=development

# ── Upload file cleanup ───────────────────────────────────────────────────────
# Uploaded audio files older than this many hours are automatically deleted.
# Set to 0 to disable cleanup.
UPLOAD_TTL_HOURS=24

# ── Redis Cache ───────────────────────────────────────────────────────────────
# Redis URL for caching AND Celery broker/backend. Falls back to in-memory cache if unavailable.
REDIS_URL=redis://localhost:6379/0

# ── Celery Task Queue ─────────────────────────────────────────────────────────
# Celery uses Redis as both broker and result backend.
# Override these if you want separate Redis instances for cache vs tasks.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Virus Scanning (ClamAV) ───────────────────────────────────────────────────
# Set to true to enable virus scanning of uploaded files via ClamAV.
# Requires ClamAV daemon running and pyclamd installed.
ENABLE_VIRUS_SCAN=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Set to true to reject files when scanning errors out (fail-closed mode)
VIRUS_SCAN_FAIL_CLOSED=false

# ── TTL Indexes (MongoDB auto-expiry) ────────────────────────────────────────
# Audit logs expire after this many days (default 90)
AUDIT_LOG_TTL_DAYS=90
# Processing status records expire after this many days (default 30)
PROCESSING_STATUS_TTL_DAYS=30

# ── Log Rotation ──────────────────────────────────────────────────────────────
# Maximum log file size in MB before rotation (default 50)
LOG_MAX_SIZE_MB=50
# Number of rotated log files to keep (default 5)
LOG_BACKUP_COUNT=5


GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match the redirect URI you registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/google-drive/callback

# ── Credential Encryption ─────────────────────────────────────────────────────
# Set a strong random string to encrypt Google OAuth credentials at rest.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, credentials are stored in plaintext (backward-compatible).
CREDENTIAL_ENCRYPTION_KEY=your-encryption-key-here

# ── Cookie Security ───────────────────────────────────────────────────────────
# Set to true in production (requires HTTPS). Marks JWT cookie as Secure.
COOKIE_SECURE=false

# ── Account Lockout ───────────────────────────────────────────────────────────
# Max failed login attempts before the account is temporarily locked.
LOCKOUT_MAX_ATTEMPTS=5
# Duration (minutes) the account stays locked after exceeding max attempts.
LOCKOUT_DURATION_MINUTES=15

# ── Structured Logging ────────────────────────────────────────────────────────
# Set to "json" to force JSON structured logging regardless of ENV.
# In production/staging mode, JSON logging is enabled automatically.
LOG_FORMAT=
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Google Drive Auto-Watcher ─────────────────────────────────────────────────
# Set to true to automatically start polling Drive on server startup.
# Requires Google auth to be completed first (credentials stored on disk).
DRIVE_AUTO_WATCH=false

# How often (in seconds) to check Drive for new files. Default: 120 (2 minutes).
DRIVE_POLL_INTERVAL_SECONDS=120

# Optional: restrict watching to a specific Google Drive folder.
# Leave blank to watch all files in Drive.
# To find a folder ID: open the folder in Drive, copy the ID from the URL.
# e.g. https://drive.google.com/drive/folders/1A2B3C4D5E  →  DRIVE_WATCH_FOLDER_ID=1A2B3C4D5E
DRIVE_WATCH_FOLDER_ID=

# ── MongoDB Connection Pooling ────────────────────────────────────────────────
# Fine-tune the MongoDB connection pool for your workload.
MONGO_POOL_MIN_SIZE=5
MONGO_POOL_MAX_SIZE=50
MONGO_MAX_IDLE_TIME_MS=30000
MONGO_WAIT_QUEUE_TIMEOUT_MS=5000

# ── Circuit Breaker ───────────────────────────────────────────────────────────
# Controls how external service failures (Ollama, S3) are handled.
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=2

# ── Disk Space Check ──────────────────────────────────────────────────────────
# Minimum free disk space (MB) required before accepting uploads.
MIN_DISK_SPACE_MB=500

# ── Celery Mode ───────────────────────────────────────────────────────────────
# Set to false to disable Celery and use threading fallback (local dev).
USE_CELERY=true
