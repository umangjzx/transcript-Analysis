# This file tells gcloud which files to skip when uploading source for Cloud Build
#!include:.gitignore
.git/
.gitignore
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.vscode/
.idea/
logs/
uploads/
reports/
examples/
tests/
.pytest_cache/
*.egg-info/
.DS_Store
Thumbs.db
node_modules/
vectors/

# Exclude training checkpoints but KEEP the final model weights
models/grooming-nli-finetuned/checkpoint-*/
models/grooming-nli-finetuned/optimizer.pt

# Exclude large training data (not needed at runtime)
# data/
