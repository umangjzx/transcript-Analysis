# Python
__pycache__/
*.py[cod]
*.pyd
*.so

# Virtual environments
venv/
.venv/
ENV/
env/

# Build / packaging
build/
dist/
*.egg-info/
.eggs/

# Test / typecheck / lint caches
.pytest_cache/
.mypy_cache/
.pytype/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# App-generated files
logs/
uploads/
reports/
vectors/chroma.sqlite3
vectors/**/*.sqlite3

# Fine-tuned ML models (large binary files — don't commit)
models/

# Google OAuth2 credentials (contains refresh tokens — never commit)
.google_credentials.json
.google_credentials.json.enc

# Environment files — NEVER commit real secrets
.env
.env.*
!.env.example

# Any encrypted credential files
*.enc

# AWS credential files
.aws/
credentials
aws_credentials.json

# Private keys / certificates
*.pem
*.key
*.p12
*.pfx

# Any file that looks like secrets
secrets.json
secrets.yaml
secrets.yml
service_account.json
